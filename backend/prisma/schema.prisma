generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  fullName     String
  email        String    @unique
  password     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  otpCode      String?
  otpExpiresAt DateTime?
  isVerified   Boolean   @default(false)
}
